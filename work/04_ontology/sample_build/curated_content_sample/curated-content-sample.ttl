    skos:prefLabel "기술" ;
    po:descriptionText "기술 개발, 상용화, 실증, 제품화, 핵심 기술 확보 관련 항목" ;
    skos:inScheme <https://example.org/kr-msit-policy/resource/scheme/resource-categories> .

<https://example.org/kr-msit-policy/resource/resource-category/infrastructure_institutional>
  a po:ResourceCategory, skos:Concept ;
